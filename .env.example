# EchoesEngine local runtime
# Copy to .env only when needed. Never commit real secrets.

# Server
ECHOES_HOST=127.0.0.1
ECHOES_PORT=8080
ECHOES_ENV=local
SITE_URL=http://127.0.0.1:8080

# Rendering/runtime safety
ECHOES_MIN_CONCURRENT_JOBS=1
ECHOES_MAX_CONCURRENT_JOBS=1
ECHOES_MAX_RETRIES=1
ECHOES_STALE_MINUTES=45
ECHOES_DEFAULT_DURATION_SECONDS=15
ECHOES_DEFAULT_RESOLUTION=1280x720

# Auto job daemon
ECHOES_AUTOJOB_ENABLED=true
ECHOES_AUTOJOB_INTERVAL_SECONDS=300
ECHOES_AUTOJOB_DURATION_SECONDS=15
ECHOES_AUTOJOB_STYLE=dark_cinematic
ECHOES_AGENT_TICK_RATE=8

# FFmpeg
# Current installed path is one level above the EchoesEngine folder:
# C:\Users\Administrator\OneDrive\Documents\EchoesEngine_complete\tools\ffmpeg\ffmpeg.exe
ECHOES_FFMPEG_DIR=C:\Users\Administrator\OneDrive\Documents\EchoesEngine_complete\tools\ffmpeg

# Optional: cloud/autopilot mode for future 24/7 operation even if laptop is off
ECHOES_AUTOPILOT_ENABLED=false
ECHOES_AUTOPILOT_WEBHOOK=https://your-automation-webhook.example.com/echoes
ECHOES_CRON_SECRET=optional_shared_secret
ECHOES_GENESIS_AT=2026-01-01T00:00:00.000Z
ECHOES_MAX_POWER_INDEX=5000
ECHOES_SIGNAL_SCORE=50
ECHOES_KPI_MODE=auto

# Optional: Upstash/Vercel KV for cloud state
KV_REST_API_URL=https://your-kv-instance.upstash.io
KV_REST_API_TOKEN=your_upstash_token

# Optional: live verification tuning
LIVE_ENDPOINTS=/generate,/status/job-1
LIVE_TIMEOUT_MS=8000

# Optional: analytics if EchoesEngine gets a public dashboard later
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=123456789012345
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=1234567
